# Database
DATABASE_URL=postgresql://delegateos:delegateos_dev@localhost:5432/delegateos

# Redis
REDIS_URL=redis://localhost:6379

# Hub Ed25519 keys (generate with: npx tsx src/utils/generate-keys.ts)
HUB_PRIVATE_KEY=
HUB_PUBLIC_KEY=

# Platform settings
PLATFORM_FEE_PERCENTAGE=5
DEFAULT_POLLING_INTERVAL_SECONDS=60
DEFAULT_SYNC_INTERVAL_HOURS=24

# Server
PORT=3000
NODE_ENV=development
HUB_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
